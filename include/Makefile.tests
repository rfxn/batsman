# batsman — Makefile.tests
# Parameterized GNU Make include for test targets
# Copyright (C) 2002-2026 R-fx Networks <proj@rfxn.com>
# GNU GPL v2 — see LICENSE
#
# Usage: Set variables, then include this file.
#
#   BATSMAN_OS_MODERN := debian12 rocky9 ubuntu2404
#   BATSMAN_OS_LEGACY := centos7 rocky8 ubuntu2004
#   BATSMAN_OS_DEEP   := centos6 ubuntu1204
#   BATSMAN_OS_EXTRA  :=
#   BATSMAN_OS_ALL    := $(BATSMAN_OS_MODERN) $(BATSMAN_OS_LEGACY) $(BATSMAN_OS_DEEP) $(BATSMAN_OS_EXTRA)
#   BATSMAN_RUN_TESTS := ./run-tests.sh
#   BATSMAN_PROJECT   := myproject    (required for clean targets)
#
#   include infra/include/Makefile.tests

# Cross-OS parallelism: 1x CPU cores, minimum 1
PARALLEL_JOBS ?= $(shell nproc 2>/dev/null || sysctl -n hw.logicalcpu 2>/dev/null || echo 1)

# ---------------------------------------------------------------------------
# Core targets (defined first so 'test' is the default goal)
# ---------------------------------------------------------------------------
.PHONY: test test-serial test-verbose test-report

test:
	$(BATSMAN_RUN_TESTS) --parallel

test-serial:
	$(BATSMAN_RUN_TESTS)

test-verbose:
	$(BATSMAN_RUN_TESTS) --formatter pretty

test-report:
	mkdir -p reports
	$(BATSMAN_RUN_TESTS) --parallel --report-dir reports
	@echo "Reports: reports/"

# ---------------------------------------------------------------------------
# Per-OS target generation: test-<os> for each OS in BATSMAN_OS_ALL
# ---------------------------------------------------------------------------
define _batsman_os_target
.PHONY: test-$(1)
test-$(1):
	$$(BATSMAN_RUN_TESTS) --os $(1) --parallel
endef

$(foreach _os,$(BATSMAN_OS_ALL),$(eval $(call _batsman_os_target,$(_os))))

# ---------------------------------------------------------------------------
# Tier group targets (sequential across OS, parallel within each)
# ---------------------------------------------------------------------------
.PHONY: test-modern test-legacy test-deep-legacy test-all

test-modern:
	for os in $(BATSMAN_OS_MODERN); do $(BATSMAN_RUN_TESTS) --os $$os --parallel || exit 1; done

test-legacy:
	for os in $(BATSMAN_OS_LEGACY); do $(BATSMAN_RUN_TESTS) --os $$os --parallel || exit 1; done

test-deep-legacy:
	@if [ -n "$(BATSMAN_OS_DEEP)" ]; then \
		for os in $(BATSMAN_OS_DEEP); do $(BATSMAN_RUN_TESTS) --os $$os --parallel || exit 1; done; \
	fi

test-all:
	for os in $(BATSMAN_OS_ALL); do $(BATSMAN_RUN_TESTS) --os $$os --parallel || exit 1; done

# ---------------------------------------------------------------------------
# Cross-OS parallel targets (multiple OS tests running concurrently)
# xargs -P returns exit 123 when any child fails but doesn't identify which
# OS target failed. The sh -c wrapper emits a failure banner to stderr.
# ---------------------------------------------------------------------------
.PHONY: test-modern-parallel test-legacy-parallel test-deep-legacy-parallel test-all-parallel

test-modern-parallel:
	printf '%s\n' $(BATSMAN_OS_MODERN) | \
	  xargs -P $(PARALLEL_JOBS) -I{} sh -c \
	    '$(BATSMAN_RUN_TESTS) --os {} --parallel || { echo "*** FAILED: {} ***" >&2; exit 1; }'

test-legacy-parallel:
	printf '%s\n' $(BATSMAN_OS_LEGACY) | \
	  xargs -P $(PARALLEL_JOBS) -I{} sh -c \
	    '$(BATSMAN_RUN_TESTS) --os {} --parallel || { echo "*** FAILED: {} ***" >&2; exit 1; }'

test-deep-legacy-parallel:
	@if [ -n "$(BATSMAN_OS_DEEP)" ]; then \
		printf '%s\n' $(BATSMAN_OS_DEEP) | \
		xargs -P $(PARALLEL_JOBS) -I{} sh -c \
		  '$(BATSMAN_RUN_TESTS) --os {} --parallel || { echo "*** FAILED: {} ***" >&2; exit 1; }'; \
	fi

test-all-parallel:
	printf '%s\n' $(BATSMAN_OS_ALL) | \
	  xargs -P $(PARALLEL_JOBS) -I{} sh -c \
	    '$(BATSMAN_RUN_TESTS) --os {} --parallel || { echo "*** FAILED: {} ***" >&2; exit 1; }'

# ---------------------------------------------------------------------------
# Image cleanup targets
# ---------------------------------------------------------------------------
# Batsman image tags follow <project>-(base|test)-<os-or-variant>.
# The -(base|test)- infix is structurally unique to batsman — no standard
# Docker images use this pattern. clean-all matches on structure alone so
# variant suffixes (e.g., yara-x) are included automatically.

.PHONY: clean clean-all clean-dangling

clean:
	@echo "=== Removing $(BATSMAN_PROJECT) images ==="
	@docker images --format '{{.Repository}}:{{.Tag}}' | \
	  grep -E '^$(BATSMAN_PROJECT)-(test|base)-' | \
	  while read -r img; do echo "  Removing $$img"; docker rmi "$$img" 2>/dev/null || true; done
	@docker image prune -f >/dev/null 2>&1 || true

clean-all:
	@echo "=== Removing all batsman project images ==="
	@docker images --format '{{.Repository}}:{{.Tag}}' | \
	  grep -E '^[a-z0-9_-]+-test-[a-z]' | \
	  while read -r img; do echo "  Removing $$img"; docker rmi "$$img" 2>/dev/null || true; done
	@docker images --format '{{.Repository}}:{{.Tag}}' | \
	  grep -E '^[a-z0-9_-]+-base-[a-z]' | \
	  while read -r img; do echo "  Removing $$img"; docker rmi "$$img" 2>/dev/null || true; done
	@docker image prune -f >/dev/null 2>&1 || true

clean-dangling:
	docker image prune -f

# ---------------------------------------------------------------------------
# UAT targets — run UAT scenario tests from tests/uat/ directory
# Uses batsman_run_direct() via -- path passthrough to BATS.
# UAT files are invisible to 'make test' (maxdepth 1 discovery).
# ---------------------------------------------------------------------------
BATSMAN_UAT_PATH ?= /opt/tests/uat/

.PHONY: uat uat-verbose

uat:
	$(BATSMAN_RUN_TESTS) -- $(BATSMAN_UAT_PATH)

uat-verbose:
	$(BATSMAN_RUN_TESTS) --formatter pretty -- $(BATSMAN_UAT_PATH)
